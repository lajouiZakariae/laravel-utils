{
    "name": "lajouizakariae/laravel-utils",
    "description": "Laravel package to publish different types of utils to laravel projects.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Zakariae Lajoui",
            "email": "lajoui.zakariae.1@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelUtils\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelUtils\\CmiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
