{
    "name": "lajouiZakariae/laravel-cmi",
    "description": "CMI (Centre Monétique Interbancaire) 3D-Secure payment integration for Laravel.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Zakariae Lajoui",
            "email": "lajoui.zakariae.1@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelCmi\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelCmi\\CmiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
